CHURNOPS_INFERENCE_HOST=0.0.0.0
CHURNOPS_INFERENCE_PORT=8000
CHURNOPS_INFERENCE_MODEL_SOURCE=mlflow_registry
CHURNOPS_INFERENCE_REGISTERED_MODEL_NAME=churnops-churn-classifier
CHURNOPS_INFERENCE_REGISTERED_MODEL_ALIAS=champion
CHURNOPS_INFERENCE_PRELOAD_MODEL=true
CHURNOPS_INFERENCE_PREDICTION_THRESHOLD=0.5
CHURNOPS_TRACKING_URI=http://mlflow:5000
CHURNOPS_REGISTRY_URI=http://mlflow:5000
CHURNOPS_DRIFT_ENABLED=true
CHURNOPS_DRIFT_STORAGE_DIR=/app/artifacts/monitoring/drift
CHURNOPS_DRIFT_WINDOW_SIZE=200
CHURNOPS_DRIFT_MIN_SAMPLES=100
CHURNOPS_DRIFT_NUMERIC_BIN_COUNT=10
CHURNOPS_DRIFT_CATEGORICAL_TOP_K=10
CHURNOPS_DRIFT_PSI_WARNING_THRESHOLD=0.1
CHURNOPS_DRIFT_PSI_DRIFT_THRESHOLD=0.25
CHURNOPS_DRIFT_MIN_DRIFTED_FEATURES=2
CHURNOPS_DRIFT_RETRAINING_ENABLED=true
CHURNOPS_DRIFT_RETRAINING_BACKEND=airflow_api
CHURNOPS_DRIFT_AIRFLOW_API_URL=http://airflow-webserver:8080/api/v1
CHURNOPS_DRIFT_AIRFLOW_DAG_ID=churnops_training_pipeline
CHURNOPS_DRIFT_RETRAINING_COOLDOWN_MINUTES=240
CHURNOPS_DRIFT_RETRAINING_REQUEST_TIMEOUT_SECONDS=10
